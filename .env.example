# Porta em que a API vai escutar
PORT=3000

# String de conexão do PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
#
# Obs.: o docker-compose expõe o Postgres na porta 5433 do HOST (para não
# conflitar com um PostgreSQL já instalado na máquina). Por isso, ao rodar
# a app/testes localmente (fora do container), use 5433.
DATABASE_URL="postgresql://blog:blog@localhost:5433/blog?schema=public"
